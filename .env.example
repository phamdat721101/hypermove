# --- Live-agent demo --------------------------------------------------------
# mock  → deterministic SSE state machine, no API keys needed (default)
# real  → call Anthropic Claude Haiku; requires ANTHROPIC_API_KEY
LIVE_AGENT_MODE=mock
ANTHROPIC_API_KEY=
AGENT_DAILY_BUDGET_USD=5

# --- x402 paywall (server side) --------------------------------------------
# Address that receives USDC payments for /api/paid-endpoint
PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000
PAYMENT_CHAIN=base-sepolia
PAYMENT_PRICE_MICRO_USDC=10000

# --- Supabase Postgres (registry storage) ----------------------------------
# Format: postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
# Leave empty to no-op: /api/v1/register will accept submissions but not persist them.
DATABASE_URL=

# --- Feature flags (default off until ship-gate) ---------------------------
FEATURE_LIVE_AGENT=true
FEATURE_PORTAL=true
FEATURE_REGISTRY=false
FEATURE_DASHBOARD=false

# --- MCP host resolution (env-driven, no domain hardcoding) ---------------
# NEXT_PUBLIC_LLM_API_URL — base URL of the standalone LLM service that runs /scan.
#   Empty → frontend uses the in-Next.js /api/scan route (pure local dev).
NEXT_PUBLIC_LLM_API_URL=http://localhost:3001
# NEXT_PUBLIC_MCP_HOST_URL — base URL embedded in the returned MCP config (frontend).
#   Defaults to NEXT_PUBLIC_LLM_API_URL → falls back to window.location.origin.
#   Set this when the LLM service is reachable under a different public hostname.
NEXT_PUBLIC_MCP_HOST_URL=
# MCP_HOST_URL — server-side override on the LLM service for the hosted MCP base.
#   Use on production deploys (e.g. https://hypermove.duckdns.org). Ignored when the
#   request includes its own `host` field.
MCP_HOST_URL=
# MCP_HOST — server-side host for /api/scan and /api/download (Next.js routes).
MCP_HOST=localhost
